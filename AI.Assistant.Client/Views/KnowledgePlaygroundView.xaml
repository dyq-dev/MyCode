<UserControl x:Class="AI.Assistant.Client.Views.KnowledgePlaygroundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:AI.Assistant.Client.Models"
             Background="{StaticResource WhiteBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Knowledge Playground"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="验证 RAG Pipeline — 输入代码相关问题，查看检索链路与上下文构建结果"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Query Input -->
        <Border Grid.Row="1"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Background="{StaticResource WhiteBrush}"
                Padding="4"
                Effect="{StaticResource SmallShadow}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Center"
                         MaxHeight="120"
                         FontSize="14"
                         Padding="12,8"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource TextPrimaryBrush}" />

                <Button Grid.Column="1"
                        Command="{Binding ExecuteQueryCommand}"
                        Margin="4,4,4,4"
                        Padding="16,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Foreground="White">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BorderBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x25B6;" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="执行查询" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- Results Area -->
        <ScrollViewer Grid.Row="2" MaxHeight="400" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <StackPanel>
                <!-- ============ Debug Info Section ============ -->
                <Border CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="RAG Debug Info"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12" />

                        <!-- Stats Grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="触发: " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.TriggeredDisplay}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="关键词: " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.Keyword}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="检索耗时: " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.RetrievalElapsed}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="构建耗时: " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.ContextBuildElapsed}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Chunks: " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.RawChunks, StringFormat='原始 {0}'}"
                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text=" → " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.ChunksAfterFilter, StringFormat='过滤 {0}'}"
                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text=" → " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.ChunksUsed, StringFormat='使用 {0}'}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Token: " FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Result.EstimatedTokens}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============ Chunks Section ============ -->
                <Border CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="检索结果"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,8" />

                        <ItemsControl ItemsSource="{Binding Result.Chunks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ChunkDisplayModel}">
                                    <Border Padding="8,6" Margin="0,2"
                                            CornerRadius="6"
                                            Background="{StaticResource WhiteBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Index, StringFormat='#{0}'}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center" />

                                            <Border Grid.Column="1"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    Background="{StaticResource AccentLightBrush}"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding ScoreDisplay}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Border>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FileLabel}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,8,0"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding ChunkType}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" />

                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Language}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ============ Context Text Section ============ -->
                <Border CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SurfaceBrush}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Context Text"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,8" />

                        <Border Background="#1E1E1E"
                                CornerRadius="6"
                                Padding="12">
                            <ScrollViewer MaxHeight="300"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding Result.ContextText}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="12"
                                           Foreground="#D4D4D4"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                VerticalAlignment="Bottom"
                Padding="4,8,4,0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8"
                         Fill="{StaticResource SuccessBrush}"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <Button Command="{Binding ClearResultCommand}"
                        FontSize="12"
                        Foreground="{StaticResource TextTertiaryBrush}"
                        Cursor="Hand"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="12,0,0,0"
                        Padding="4,0">
                    <TextBlock Text="清空" TextDecorations="Underline" />
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result.Triggered}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
