<Window x:Class="AI.Assistant.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI Assistant"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="400" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============================================
             LEFT SIDEBAR
             ============================================ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="16,16,16,12">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource AccentBrush}"
                                CornerRadius="8"
                                Width="32" Height="32"
                                Margin="0,0,10,0">
                            <Path Data="M6,18 L10,18 L10,22 L6,22 Z M14,6 L14,10 L18,10 L18,6 Z M2,12 C2,6.48 6.48,2 12,2 C17.52,2 22,6.48 22,12 C22,17.52 17.52,22 12,22 C6.48,22 2,17.52 2,12 Z"
                                  Fill="White"
                                  Stretch="Uniform"
                                  Width="18" Height="18" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="AI Assistant"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Powered by LLM"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- New Chat Button -->
                <Border Grid.Row="1" Padding="12,0,12,8">
                    <Button Command="{Binding NewConversationCommand}"
                            Style="{StaticResource NewChatButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0">
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="+"
                                       FontSize="16"
                                       FontWeight="Light"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="新建对话"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </Border>

                <!-- Conversation List -->
                <Border Grid.Row="2" Padding="8,0,8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Conversations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Margin="0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button Style="{StaticResource ConversationItemButton}"
                                                    Grid.ColumnSpan="3"
                                                    Command="{Binding DataContext.SelectConversationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{StaticResource SurfaceBrush}"
                                                            CornerRadius="6"
                                                            Width="22" Height="22"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="&#x1F4AC;"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0" />
                                                </Grid>
                                            </Button>

                                            <!-- Delete button -->
                                            <Button Grid.Column="2"
                                                    Content="&#x2715;"
                                                    ToolTip="删除对话"
                                                    Command="{Binding DataContext.DeleteConversationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource DeleteButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="3"
                        Padding="12,8"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock Text="v1.0.0"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Resize Handle -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE" />

        <!-- ============================================
             RIGHT - Chat Area
             ============================================ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Padding="20,14,20,14"
                    Background="{StaticResource WhiteBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource AccentLightBrush}"
                                CornerRadius="8"
                                Width="32" Height="32"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#x1F4AC;"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding CurrentConversation.Title, FallbackValue='新对话'}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Status -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource SuccessBrush}"
                                 Margin="0,0,6,0" />
                        <TextBlock Text="就绪"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================
                 Messages Area
                 ============================================ -->
            <Border Grid.Row="1" Background="{StaticResource WhiteBrush}">
                <ScrollViewer x:Name="MessagesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0">
                    <ItemsControl ItemsSource="{Binding CurrentConversation.Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- System message -->
                                        <Border Grid.ColumnSpan="2"
                                                HorizontalAlignment="Center"
                                                MaxWidth="600"
                                                Padding="14,10"
                                                CornerRadius="8"
                                                Background="#FEF3C7"
                                                BorderBrush="#FDE68A"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       FontSize="13"
                                                       Foreground="#92400E"
                                                       TextAlignment="Center" />
                                        </Border>

                                        <!-- Assistant message -->
                                        <Border Grid.Column="0"
                                                MaxWidth="750"
                                                Padding="16,12"
                                                Margin="60,0,80,0"
                                                VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource AssistantBubbleBrush}" />
                                                    <Setter Property="CornerRadius" Value="12" />
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{StaticResource AccentBrush}"
                                                            CornerRadius="6"
                                                            Width="24" Height="24"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="AI"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="助手"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DisplayTime}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextTertiaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontSize="14"
                                                           LineHeight="22"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Grid>
                                        </Border>

                                        <!-- User message -->
                                        <Border Grid.Column="1"
                                                MaxWidth="700"
                                                Padding="14,10"
                                                Margin="80,0,60,0"
                                                VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource UserBubbleBrush}" />
                                                    <Setter Property="CornerRadius" Value="12" />
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="你"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#9CA3AF"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontSize="14"
                                                           LineHeight="22"
                                                           Foreground="{StaticResource TextOnDarkBrush}" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- ============================================
                 Input Area
                 ============================================ -->
            <Border Grid.Row="2"
                    Padding="20,12,20,20"
                    Background="{StaticResource WhiteBrush}">
                <Grid HorizontalAlignment="Center" Width="760">
                    <Border CornerRadius="24"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource WhiteBrush}"
                            Padding="6"
                            Effect="{StaticResource SmallShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="12,0,4,0">
                                <TextBlock Text=" 输入消息... (Ctrl+Enter 发送)"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           FontSize="15"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Margin="0,8,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer MaxHeight="200"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBox x:Name="InputTextBox"
                                             Style="{StaticResource InputTextBox}"
                                             Text="{Binding CurrentConversation.InputText, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Center">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter"
                                                        Modifiers="Control"
                                                        Command="{Binding CurrentConversation.SendMessageCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </ScrollViewer>
                            </Grid>

                            <Button Grid.Column="1"
                                    Command="{Binding CurrentConversation.SendMessageCommand}"
                                    Style="{StaticResource SendButton}"
                                    Margin="4,0,2,0"
                                    VerticalAlignment="Bottom"
                                    ToolTip="发送消息 (Ctrl+Enter)" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
